#!/bin/sh

# Editor stuff
alias vim="nvim"
alias v="nvim"

# Configuration stuff
alias conf-dotfiles="cd $DOTFILES && nvim"

# Single file configuration
alias conf-picom="nvim $DOTFILES/.config/picom.conf"
alias conf-aliases="nvim $DOTFILES/.config/sh/aliases"
alias conf-environment="nvim $DOTFILES/.config/environment"
alias conf-gtkrc-2.0="nvim $DOTFILES/.gtkrc-2.0"

# Configure desktop shortcuts
alias conf-desktop="nvim $HOME/.local/share/applications"

# Directory configuration
alias conf-bspwm="cd $DOTFILES/.config/bspwm && nvim bspwmrc"
alias conf-nvim="cd $DOTFILES/.config/nvim && nvim init.vim"
alias conf-rofi="cd $DOTFILES/.config/rofi && nvim config.rasi"
alias conf-kitty="cd $DOTFILES/.config/kitty && nvim kitty.conf"
alias conf-polybar="cd $DOTFILES/.config/polybar && nvim config"
alias conf-dunst="cd $DOTFILES/.config/dunst && nvim dunstrc"
alias conf-gtk-3.0="cd $DOTFILES/.config/gtk-3.0 && nvim settings.ini"
alias conf-sxhkd="cd $DOTFILES/.config/sxhkd && nvim sxhkdrc"
alias conf-vis="cd $DOTFILES/.config/vis && nvim config"
