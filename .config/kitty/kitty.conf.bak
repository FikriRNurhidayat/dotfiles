# BEGIN_KITTY_THEME
# Catppuccin-Mocha
include current-theme.conf
# END_KITTY_THEME

font_family      Fixedsys Excelsior
font_size        10.0
tab_bar_style    powerline

background_opacity 0.9

window_padding_width 16
window_border_width  0

force_ltr yes

map ctrl+shift+enter new_window_with_cwd
symbol_map U+23FB-U+23FE,U+2B58,U+1F300-U+1F5FF,U+1F600-U+1F64F,U+1F680-U+1F6FF,U+1F700-U+1F77F Symbols Nerd Font
