{
    "height": 48,
    "spacing": 32,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock#time"],
    "modules-right": ["battery", "network", "clock#date", "clock#week", "tray"],
    "sway/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "火",
            "2": "水",
            "3": "氣",
            "4": "塵",
            "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十",
            "Urgent": "死"
        }
    },
    "tray": {
        "icon-size": 12,
        "spacing": 32
    },
    "clock#date": {
        "format": "{:%d %B %Y}"
    },
    "clock#time": {
        "format": "{:%H:%M}"
    },
    "clock#week": {
        "format": "Week {:%W}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}%  {icon}",
        "format-plugged": "{capacity}%  {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format-wifi": "󰅟",
        "format-ethernet": "󰅟",
        "format-linked": "󰅟",
        "format-disconnected": "󰅤",
        "format-alt": "{essid} 󰅟"
    }
}

