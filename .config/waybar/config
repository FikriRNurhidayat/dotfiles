{
    "height": 32,
    "spacing": 32,
    "margin-top": 16,
    "margin-left": 16,
    "margin-right": 16,
    "margin-bottom": 16,
    "modules-left": ["custom/arch-icon", "sway/workspaces"],
    "modules-center": ["clock#time"],
    "modules-right": ["battery", "network", "clock#date", "clock#week", "tray"],
    "hyprland/workspaces": {
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ꦲ",
            "2": "ꦤ",
            "3": "ꦕ",
            "4": "ꦫ",
            "5": "ꦏ",
            "6": "ꦢ",
            "7": "ꦠ",
            "8": "ꦱ",
            "9": "ꦮ",
            "10": "ꦭ" 
        }
    },
    "sway/workspaces": {
        "persistant_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        },
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ꦲ",
            "2": "ꦤ",
            "3": "ꦕ",
            "4": "ꦫ",
            "5": "ꦏ",
            "6": "ꦢ",
            "7": "ꦠ",
            "8": "ꦱ",
            "9": "ꦮ",
            "10": "ꦭ" 
        }
    },
    "tray": {
        "icon-size": 12,
        "spacing": 32
    },
    "clock#date": {
        "format": "{:%d %B %Y}"
    },
    "clock#time": {
        "format": "{:%H:%M}"
    },
    "clock#week": {
        "format": "Week {:%W}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}%  {icon}",
        "format-plugged": "{capacity}%  {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format-wifi": "󰅟",
        "format-ethernet": "󰅟",
        "format-linked": "󰅟",
        "format-disconnected": "󰅤",
        "format-alt": "{essid} 󰅟"
    },
    "custom/arch-icon": {
      "format": ""
    }
}

