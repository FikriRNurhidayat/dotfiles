theme                      = "GruvboxDark"
background-opacity         = 0.69
keybind                    = clear
font-size                  = 10
font-family                = "JetBrains Mono"
window-padding-x           = 16
window-padding-y           = 16
shell-integration-features = sudo,no-cursor,no-title 
desktop-notifications      = false
confirm-close-surface      = false

keybind                    = ctrl+shift+c=copy_to_clipboard
keybind                    = ctrl+shift+v=paste_from_clipboard
keybind                    = ctrl+shift+r=reload_config
keybind                    = ctrl+space>c=new_tab
keybind                    = ctrl+space>n=next_tab
keybind                    = ctrl+space>p=previous_tab
keybind                    = ctrl+space>s=new_split:down
keybind                    = ctrl+space>v=new_split:right
keybind                    = ctrl+space>z=toggle_split_zoom
keybind                    = ctrl+j=goto_split:down
keybind                    = ctrl+k=goto_split:up
keybind                    = ctrl+l=goto_split:right
keybind                    = ctrl+h=goto_split:left

gtk-titlebar               = true
gtk-single-instance        = true
gtk-tabs-location          = hidden
gtk-wide-tabs              = true

window-padding-balance = true
window-padding-color = background
window-inherit-working-directory = true
window-inherit-font-size = true
