#!/usr/bin/env bash

# Terminate already running bar instances
killall -q polybar

# Wait until the processes have been shut down
while pgrep -u $UID -x polybar >/dev/null; do sleep 1; done

# Launch the preview bar
polybar -q main -c "$HOME"/Repositories/dotfiles/.config/polybar/config.ini 2>/tmp/polybar.error.log &
polybar -q bottom -c "$HOME"/Repositories/dotfiles/.config/polybar/config.ini 2>/tmp/polybar.error.log &
