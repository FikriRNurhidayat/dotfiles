#!/bin/sh

# The next line updates PATH for the rvm
export PATH="$PATH:$HOME/.rvm/bin"

# The next line updates PATH for the Yarn
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"

# The next lines set new variables for Golang
# also it updates PATH for golang binaries
export GOARCH="amd64"
export GOPATH="$HOME/Repositories/GO"
export PATH=$PATH:$GOROOT/bin:$GOPATH/bin

# Doom emacs
export PATH="$PATH:$HOME/.config/emacs/bin"

# Deno
export DENO_INSTALL="/home/fain/.deno"
export PATH="$DENO_INSTALL/bin:$PATH"

# Adds custom scripts and binaries
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$HOME/.local/scripts"
export PATH="$PATH:$HOME/.scripts"

# Android
export PATH="$PATH:$HOME/Android/Sdk/tools/bin"

# Flutter
export PATH="$PATH:$HOME/.pub-cache/bin"

# Configuration stuff
export DOTFILES="$HOME/.dotfiles"

# Flutter requires chome sadly.
export CHROME_EXECUTABLE="brave"

# GKE Things
# The next line updates PATH for the Google Cloud SDK.
if [ -f '/home/fain/.local/share/google-cloud-sdk/path.zsh.inc' ]; then . '/home/fain/.local/share/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/home/fain/.local/share/google-cloud-sdk/completion.zsh.inc' ]; then . '/home/fain/.local/share/google-cloud-sdk/completion.zsh.inc'; fi

export USE_GKE_GCLOUD_AUTH_PLUGIN=True
