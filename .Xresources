! X colors.
! Generated by 'wal'
*foreground:        #e4e9f0
*background:        #0a0d16
*.foreground:       #e4e9f0
*.background:       #0a0d16
emacs*foreground:   #e4e9f0
emacs*background:   #0a0d16
URxvt*foreground:   #e4e9f0
XTerm*foreground:   #e4e9f0
UXTerm*foreground:  #e4e9f0
URxvt*background:   [100]#0a0d16
XTerm*background:   #0a0d16
UXTerm*background:  #0a0d16
URxvt*cursorColor:  #e4e9f0
XTerm*cursorColor:  #e4e9f0
UXTerm*cursorColor: #e4e9f0
URxvt*borderColor:  [100]#0a0d16

! Colors 0-15.
*.color0: #0a0d16
*color0:  #0a0d16
*.color1: #C2BDB6
*color1:  #C2BDB6
*.color2: #9FB2CD
*color2:  #9FB2CD
*.color3: #B2C5DC
*color3:  #B2C5DC
*.color4: #B3CFEE
*color4:  #B3CFEE
*.color5: #C7CED8
*color5:  #C7CED8
*.color6: #CCDAEE
*color6:  #CCDAEE
*.color7: #e4e9f0
*color7:  #e4e9f0
*.color8: #9fa3a8
*color8:  #9fa3a8
*.color9: #C2BDB6
*color9:  #C2BDB6
*.color10: #9FB2CD
*color10:  #9FB2CD
*.color11: #B2C5DC
*color11:  #B2C5DC
*.color12: #B3CFEE
*color12:  #B3CFEE
*.color13: #C7CED8
*color13:  #C7CED8
*.color14: #CCDAEE
*color14:  #CCDAEE
*.color15: #e4e9f0
*color15:  #e4e9f0

! Black color that will not be affected by bold highlighting.
*.color66: #0a0d16
*color66:  #0a0d16

! Xclock colors.
XClock*foreground: #e4e9f0
XClock*background: #0a0d16
XClock*majorColor:  rgba:e4/e9/f0/ff
XClock*minorColor:  rgba:e4/e9/f0/ff
XClock*hourColor:   rgba:e4/e9/f0/ff
XClock*minuteColor: rgba:e4/e9/f0/ff
XClock*secondColor: rgba:e4/e9/f0/ff

! Set depth to make transparency work.
URxvt*depth: 32

! DWM
dwm.normbordercolor: #e4e9f0
dwm.normbgcolor: #0a0d16
dwm.normfgcolor: #e4e9f0
dwm.selbordercolor: #e4e9f0
dwm.selbgcolor: #0a0d16
dwm.selfgcolor: #e4e9f0